# llama compose configuration.
# Copy this file to .env (same folder) and edit. Per node you set MODEL (+ LoRA).
# The path keys (MODELS_DIR/LORA_DIR) are FIXED — they point at the .temp view
# isannd assembles from the store; do not edit them.

# ---- Profile metadata (set by broker UI when applying a profile) ------------
# 운영자가 broker UI 에서 프로파일을 적용하면 PROFILE_NAME / PROFILE_APPLIED_AT
# 가 자동으로 갱신됨. 수동으로 .env 만 편집한 경우엔 "custom" 으로 둬도 됨.
PROFILE_NAME=default
PROFILE_APPLIED_AT=

# ---- Image -------------------------------------------------------------------
IMAGE_NAME=ghcr.io/isannai/llama
IMAGE_TAG=latest
CONTAINER_NAME=llama

# ---- Network -----------------------------------------------------------------
# Localhost-only debug port — compose binds it to 127.0.0.1, NOT exposed to the
# network. Container internal port is fixed at 8080 (unified across engines;
# the provider dials this host port to reach the engine).
PORT=7862

# Static IP on the `isann` docker network (10.10.1.0/24). Convention:
#   10.10.1.11   sd
#   10.10.1.12   vllm
#   10.10.1.13   llama  (this one)
#   10.10.1.101  provider
#   10.10.1.111  broker
#   10.10.1.201  rendezvous
IP=10.10.1.13

# ---- Storage -----------------------------------------------------------------
# FIXED path key — points at the .temp view isannd assembles (by hardlink) from
# the canonical store (artifacts/addon/models/llama/) on `docker prepare llama` /
# `docker start llama -prepare`. Same on Windows+WSL / Linux / macOS.
# Do NOT edit MODELS_DIR — set MODEL below.
MODELS_DIR=./.temp/models/defaults

# Model 파일 (gguf 단일 파일). in-view 경로 <store-dir-name>/<file>, MODELS_DIR
# 기준 상대 (체크포인트는 store/llama/defaults/<store-dir-name>/ 에 있음).
# 컨테이너 안에선 /models/<MODEL> 로 보임.
MODEL=Qwen2.5-1.5B-Q4_K_M/Qwen2.5-1.5B-Instruct-Q4_K_M.gguf

# OpenAI API 가 노출할 모델 이름. 빈 값이면 llama-server 가 자동 결정.
SERVED_MODEL_NAME=

# ---- llama-server runtime knobs ----------------------------------------------
# Context window (--ctx-size, -c). 전체 슬롯이 나눠 쓰는 총 context (슬롯당 = CTX_SIZE/PARALLEL).
# 모델 capability 초과하면 일부 모델은 RoPE scaling 자동.
CTX_SIZE=8192

# GPU 에 올릴 레이어 수 (--n-gpu-layers, -ngl). 99 = 전부. 0 = CPU only. 작게 잡으면 메모리 절약.
GPU_LAYERS=99

# 멀티 GPU split 모드 (--split-mode, -sm). 단일 GPU 면 무시. none | layer | row | tensor.
#   layer  = 레이어+KV 를 GPU 에 분할 (기본·pipelined·VRAM 분산)
#   row    = weight 를 row 로 분할 (parallelized·throughput↑; KV/main 은 -mg GPU)
#   none   = GPU 1개만 사용 (어느 GPU 인지는 -mg)
#   tensor = weight+KV 분할 (parallelized, EXPERIMENTAL)
# 빈 값 = llama-server 기본(layer).
# GPU 비율(-ts)·main GPU(-mg) 는 EXTRA_LLAMA_ARGS 로:
#   EXTRA_LLAMA_ARGS="--tensor-split 3,1 --main-gpu 0"
SPLIT_MODE=

# 동시 처리 슬롯 수 = 동시 추론 수 (--parallel, -np). 기본 1. 슬롯당 context = CTX_SIZE/PARALLEL.
# provider 큐 worker 수는 이 값을 자동 추종 (manifest concurrency_env) — 동시 처리 수는 여기 한 곳만 조정.
PARALLEL=1

# /slots 모니터링 엔드포인트 (--slots / --no-slots). on | off. 빈 값 = llama 기본(enabled).
# ⚠️ on 이면 GET /slots 로 각 슬롯의 프롬프트/상태가 노출됨 → 외부 노출 노드면 off 권장.
SLOTS=

# CPU 스레드 수 (--threads, -t). 빈 값 = llama-server 가 자동 (논리 코어 기준).
THREADS=

# KV cache 양자화: 빈 값 = f16 (기본·권장).
# q8_0 등 양자화 타입은 V 캐시 양자화에 flash attention 이 필요해서
# run.sh 가 자동으로 --flash-attn on 을 붙인다 (GPU 가 FA 를 지원해야 함).
# q4_0 는 품질 손실이 커서 (특히 작은 모델은 난수 수준으로 깨질 수 있음)
# 권장하지 않음. VRAM 이 빠듯하면 q8_0 부터 시도.
KV_TYPE=

# Chat template — 모델에 맞게 명시 (chatml / llama3 / qwen / gemma / 등).
# 빈 값 = 모델의 chat_template 메타에서 자동 추출.
CHAT_TEMPLATE=

# mmap 끄고 일반 로딩 — 일부 NFS / 윈도우 마운트 환경에서 mmap 깨질 때.
# 빈 값 = mmap 사용 (기본 권장).
NO_MMAP=

# mlock — 모델을 RAM 에 lock 해서 스왑 방지. root 권한 또는 ulimit 조정 필요.
MLOCK=

# ---- LoRA --------------------------------------------------------------------
# LORA_DIR — FIXED view path, mounted at /loras. isannd assembles ALL of
# store/llama/loras/ here as flat <name>.gguf (the dir always exists, even
# empty). 무엇이 실제 load 되는지는 LORA_ADAPTERS 가 결정 — 비어 있으면 LoRA 없음.
LORA_DIR=./.temp/models/loras

# LORA_ADAPTERS — 로드할 LoRA 어댑터 목록 (공백 구분, /loras 기준 상대 경로).
# flat 이름 = store 폴더명 + .gguf. 예: anime.gguf (= store/llama/loras/anime/).
# 단순 형식 (scale=1.0):
#   LORA_ADAPTERS="anime.gguf detail.gguf"
# scale 지정 형식:
#   LORA_ADAPTERS="anime.gguf=0.8 detail.gguf=1.2"
# 혼용 가능. llama.cpp 는 여러 LoRA 동시 로드 지원.
LORA_ADAPTERS=

# ---- Catch-all ---------------------------------------------------------------
# Any extra llama-server flags, appended verbatim.
# Example: EXTRA_LLAMA_ARGS=--flash-attn --no-context-shift
EXTRA_LLAMA_ARGS=
