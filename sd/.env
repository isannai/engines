# sd compose configuration.
# Copy this file to .env (same folder) and edit. Per node you set ARCH + MODEL
# (+ VAE_FILE). The path keys (MODELS_DIR/VAE_DIR/LORA_DIR) are FIXED — they
# point at the .temp view isannd assembles from the store; do not edit them.

# ---- Profile metadata (set by broker UI when applying a profile) ------------
# 운영자가 broker UI 에서 프로파일을 적용하면 PROFILE_NAME / PROFILE_APPLIED_AT
# 가 자동으로 갱신됨. 수동으로 .env 만 편집한 경우엔 "custom" 으로 둬도 됨.
PROFILE_NAME=default
PROFILE_APPLIED_AT=

# ---- Image -------------------------------------------------------------------
IMAGE_NAME=ghcr.io/isannai/sd
IMAGE_TAG=latest
CONTAINER_NAME=sd

# ---- Network -----------------------------------------------------------------
# Localhost-only debug port — compose binds it to 127.0.0.1, NOT exposed to the
# network. Container internal port is fixed at 8080 (unified across engines;
# the provider dials this host port to reach the engine).
PORT=7860

# Static IP on the `isann` docker network (10.10.1.0/24). Convention:
#   10.10.1.11   sd  (this one)
#   10.10.1.12   vllm
#   10.10.1.13   llama
#   10.10.1.101  provider
#   10.10.1.111  broker
#   10.10.1.201  rendezvous
# Network must exist on the host first — create once with:
#   docker network create --driver bridge --subnet=10.10.1.0/24 --gateway=10.10.1.1 isann
IP=10.10.1.11

# ---- Storage -----------------------------------------------------------------
# FIXED path keys — they point at the .temp view that isannd assembles (by
# hardlink) from the canonical store (artifacts/addon/models/) on
# `docker prepare sd` / `docker start sd -prepare`. Same on Windows+WSL / Linux /
# macOS. Do NOT edit MODELS_DIR/VAE_DIR/LORA_DIR — set ARCH + MODEL below.
MODELS_DIR=./.temp/models/defaults

# ARCH — which sd architecture subtree to assemble into the view
# (sd15 | sdxl | sd3 | pony | flux). isannd pulls model/loras/vae from
# store/sd/<ARCH>/ — changing ARCH swaps the entire view to that arch's assets.
ARCH=sd15

# MODEL — in-view path to the checkpoint: <store-dir-name>/<file>, RELATIVE to
# MODELS_DIR (the checkpoint lives in store/sd/<ARCH>/defaults/<store-dir-name>/).
# e.g. v1-5-pruned-emaonly/v1-5-pruned-emaonly.safetensors
MODEL=v1-5-pruned-emaonly/v1-5-pruned-emaonly.safetensors

# Host directory where generated images go (created if missing).
OUTPUTS_DIR=./outputs

# ---- Optional model satellites (each its own mount) -------------------------
# Separate volumes at /vae and /loras. VAE_DIR / LORA_DIR are FIXED view paths
# (always exist — isannd pre-creates them even when empty). What you choose is
# VAE_FILE; loras are not listed (sd picks them from the prompt).

# VAE_DIR — FIXED view path, mounted at /vae. VAE_FILE selects which one.
VAE_DIR=./.temp/models/vaes
# VAE_FILE — in-view path <store-dir-name>/<file>. Blank = skip VAE.
# Example: sdxl-vae/sdxl-vae.safetensors
VAE_FILE=

# LORA_DIR — FIXED view path, mounted at /loras (--lora-model-dir). isannd
# assembles ALL of store/sd/<ARCH>/loras/ here as flat <name>.safetensors;
# sd-server matches by name from the prompt (`<lora:name:weight>`). Nothing to
# list — the whole arch lora set is available.
LORA_DIR=./.temp/models/loras

# ---- sd-server inference defaults --------------------------------------------
# These apply to every request — sd.cpp does not honor per-request overrides
# for these. To change at runtime, edit and `docker compose ... up -d` again.
STEPS=20
CFG_SCALE=7
SAMPLE_METHOD=

# ---- Resource knobs ----------------------------------------------------------
THREADS=
VAE_ON_CPU=
CLIP_ON_CPU=

# ---- Catch-all ---------------------------------------------------------------
# Any extra sd-server flags, appended verbatim.
# Example: EXTRA_SD_ARGS=--type q4_0 --diffusion-flash-attn
EXTRA_SD_ARGS=
